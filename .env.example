# ── Spark ──────────────────────────────────────────────────────────────────────
# For standalone cluster: spark://master:7077
# For Dataproc / YARN: yarn
# For local dev: local[*]
SPARK__MASTER=spark://cluster-master:7077
SPARK__APP_NAME=us-accidents-etl
SPARK__EXECUTOR_MEMORY=8g
SPARK__DRIVER_MEMORY=4g
SPARK__EXECUTOR_CORES=4
# ── ETL paths ──────────────────────────────────────────────────────────────────
ETL__INPUT_PATH=gs://my-bucket/raw/US_Accidents_March23.csv
ETL__OUTPUT_PATH=gs://my-bucket/processed/us_accidents
ETL__MIN_SEVERITY=3
# JSON list
ETL__WEATHER_CONDITIONS=["Rain","Snow"]
